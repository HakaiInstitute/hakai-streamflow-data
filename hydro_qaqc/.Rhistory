size = 0.5) +
geom_line(data = Rating_RC2,
aes(x = Stage_avg, y = Q_model, colour = smoothed)) +
theme_bw() +
xlab("Stage (cm)") + ylab("Discharge (m³/s)") +
labs(title = "RC2 -- LOESS span selection")
)
## ACTION REQUIRED: enter chosen span label and value
RC2_span_label <- "span_b"
RC2_span_value <- 0.4
Rating_RC2 <- Rating_RC2 |>
filter(smoothed == RC2_span_label) |>
dplyr::select(Stage_avg, Q_model)
h0_RC2 <- min(HQ_RC2$Stage_avg[HQ_RC2$Q_meas > 0], na.rm = TRUE) * 0.9
## ACTION REQUIRED: set inflection point manually
## Power law will be fitted only on gaugings at or above this stage
inflection_h_RC2 <- 150
# Fit power law only above the inflection point
RC2_extrap_data <- HQ_RC2 |>
filter(Stage_avg >= inflection_h_RC2, Q_meas > 0)
# Derive starting values from log-log linear model
RC2_loglog   <- RC2_extrap_data |>
mutate(log_h = log(Stage_avg - h0_RC2), log_Q = log(Q_meas))
lm_start_RC2 <- lm(log_Q ~ log_h, data = RC2_loglog)
a_start_RC2  <- exp(coef(lm_start_RC2)[1])
b_start_RC2  <- coef(lm_start_RC2)[2]
fit_RC2 <- tryCatch(
nls(Q_meas ~ a * (Stage_avg - h0)^b,
data    = RC2_extrap_data,
start   = list(a = a_start_RC2, b = b_start_RC2, h0 = h0_RC2),
control = nls.control(maxiter = 500)),
error = function(e) {
message("RC2 nls failed with free h0 -- falling back to fixed h0")
nls(Q_meas ~ a * (Stage_avg - h0_RC2)^b,
data    = RC2_extrap_data,
start   = list(a = a_start_RC2, b = b_start_RC2),
control = nls.control(maxiter = 500))
}
)
RC2_max_loess <- max(Rating_RC2$Stage_avg)
last_loess_Q  <- Rating_RC2$Q_model[which.max(Rating_RC2$Stage_avg)]
# Force power law through last LOESS point -- fit only b, back-calculate a
fit_RC2_b <- tryCatch(
nls(Q_meas ~ (last_loess_Q / (RC2_max_loess - h0_RC2)^b) * (Stage_avg - h0_RC2)^b,
data    = RC2_extrap_data,
start   = list(b = b_start_RC2),
control = nls.control(maxiter = 500)),
error = function(e) {
message("RC2 constrained fit failed -- using unconstrained fit")
fit_RC2
}
)
# Use constrained fit if successful, fall back to unconstrained
if (!inherits(fit_RC2_b, "nls") == FALSE) {
b_RC2 <- coef(fit_RC2_b)["b"]
a_RC2 <- last_loess_Q / (RC2_max_loess - h0_RC2)^b_RC2
} else {
b_RC2 <- coef(fit_RC2)["b"]
a_RC2 <- coef(fit_RC2)["a"]
}
RC2_extrap_stage  <- seq(RC2_max_loess + 1, 218, by = 1)
RC2_extrap_Q      <- a_RC2 * (RC2_extrap_stage - h0_RC2)^b_RC2
RC2_extrap_values <- tibble(Stage_avg = RC2_extrap_stage, Q_model = RC2_extrap_Q)
Rating_RC2_full   <- bind_rows(Rating_RC2, RC2_extrap_values) |> arrange(Stage_avg)
# Extend interpolated table to cover Stage_avg + Stage_stdv for all gaugings
# HQ_unc adds Stage_stdv before lookup -- must be within table range
max_stage_plus_stdv <- max(HQ_RC2$Stage_avg + HQ_RC2$Stage_stdv, na.rm = TRUE)
Rating_RC2_full_ext <- bind_rows(
Rating_RC2_full,
tibble(Stage_avg = seq(max(Rating_RC2_full$Stage_avg) + 1,
ceiling(max_stage_plus_stdv) + 1,
by = 1),
Q_model   = last_loess_Q)
) |> arrange(Stage_avg)
